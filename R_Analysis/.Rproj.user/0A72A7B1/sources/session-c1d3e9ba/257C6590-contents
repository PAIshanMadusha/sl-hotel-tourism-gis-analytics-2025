# Project: Statistical and Business Analytics of Hotel Revenue

if (!require(psych)) install.packages("psych")
if (!require(car)) install.packages("car")
if (!require(ggplot2)) install.packages("ggplot2")

# 1. Clear Environment
rm(list = ls())

# 2. Load Required Libraries
library(ggplot2)
library(psych)
library(car)

# 3. Load Dataset
hotel <- read.csv("../Data/HOTELS_2025.csv")

# 4. Data Inspection
str(hotel)
summary(hotel)
head(hotel)

# 5. Descriptive Statistics
describe(hotel[, c("RoomsAvailable",
                   "OccupancyRate",
                   "ADR",
                   "MarketingSpend",
                   "StaffCount",
                   "GuestSatisfactionScore",
                   "LoyaltyMembers",
                   "Revenue")])

# 6. Normality Tests (Hypothesis-based)
shapiro.test(hotel$Revenue)
shapiro.test(hotel$OccupancyRate)
shapiro.test(hotel$ADR)
shapiro.test(hotel$MarketingSpend)
shapiro.test(hotel$GuestSatisfactionScore)

# 7. Histograms (Distribution Analysis)
hist(hotel$Revenue,
     main = "Distribution of Hotel Revenue",
     xlab = "Revenue (USD)",
     col = "lightblue")

hist(hotel$OccupancyRate,
     main = "Distribution of Occupancy Rate",
     xlab = "Occupancy Rate",
     col = "lightgreen")

hist(hotel$ADR,
     main = "Distribution of ADR",
     xlab = "ADR (USD)",
     col = "lightyellow")


# 8. Correlation Analysis
cor.test(hotel$Revenue, hotel$OccupancyRate, method = "pearson")
cor.test(hotel$Revenue, hotel$ADR, method = "pearson")
cor.test(hotel$Revenue, hotel$MarketingSpend, method = "pearson")
cor.test(hotel$Revenue, hotel$GuestSatisfactionScore, method = "pearson")
cor.test(hotel$Revenue, hotel$LoyaltyMembers, method = "pearson")

# 9. Scatter Plots with Regression Line

# Revenue vs Occupancy Rate
plot(hotel$OccupancyRate, hotel$Revenue,
     xlab = "Occupancy Rate",
     ylab = "Revenue (USD)",
     main = "Revenue vs Occupancy Rate")
abline(lm(Revenue ~ OccupancyRate, data = hotel), col = "red", lwd = 2)

# Revenue vs ADR
plot(hotel$ADR, hotel$Revenue,
     xlab = "Average Daily Rate (ADR)",
     ylab = "Revenue (USD)",
     main = "Revenue vs ADR")
abline(lm(Revenue ~ ADR, data = hotel), col = "blue", lwd = 2)

# Revenue vs Marketing Spend
plot(hotel$MarketingSpend, hotel$Revenue,
     xlab = "Marketing Spend (USD)",
     ylab = "Revenue (USD)",
     main = "Revenue vs Marketing Spend")
abline(lm(Revenue ~ MarketingSpend, data = hotel), col = "darkgreen", lwd = 2)


# 10. Simple Linear Regression Models
model_occ <- lm(Revenue ~ OccupancyRate, data = hotel)
summary(model_occ)

model_adr <- lm(Revenue ~ ADR, data = hotel)
summary(model_adr)

model_marketing <- lm(Revenue ~ MarketingSpend, data = hotel)
summary(model_marketing)

# 11. Multiple Linear Regression Model
model_full <- lm(Revenue ~ RoomsAvailable +
                   OccupancyRate +
                   ADR +
                   MarketingSpend +
                   GuestSatisfactionScore +
                   LoyaltyMembers,
                 data = hotel)

summary(model_full)

# 12. Multicollinearity Check
vif(model_full)

# 13. Model Diagnostics
par(mfrow = c(2,2))
plot(model_full)

# 14. ANOVA Test (Overall Model Significance)
anova(model_full)

# 15. Save Key Plots
png("../R_Analysis/Revenue_vs_Occupancy.png")
plot(hotel$OccupancyRate, hotel$Revenue,
     xlab = "Occupancy Rate",
     ylab = "Revenue (USD)",
     main = "Revenue vs Occupancy Rate")
abline(lm(Revenue ~ OccupancyRate, data = hotel), col = "red", lwd = 2)
dev.off()




